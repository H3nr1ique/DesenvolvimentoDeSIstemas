programa
{
    funcao inicio()
    {
        real precoOriginal, percentualDesconto, valorDesconto, precoComDesconto

        escreva("Escreva o preço original: ")
        leia(precoOriginal)

        percentualDesconto = 10
        
        valorDesconto = precoOriginal * (percentualDesconto / 100)
        precoComDesconto = precoOriginal - valorDesconto
        
        escreva("Preço original: R$ ", precoOriginal, "\n")
        escreva("Desconto (", percentualDesconto, "%): R$ ", valorDesconto, "\n")
        escreva("Preço com desconto: R$ ", precoComDesconto)
    }
}
